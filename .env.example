# ── AI Provider ──────────────────────────────────────────────────────────────
# Copy backend/.env.example → backend/.env and fill these in:
ANTHROPIC_API_KEY=sk-ant-...
MODEL_NAME=claude-opus-4-6          # optional, defaults to claude-opus-4-6

# ── Composio ──────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=...
AUTH_CONFIG_ID=...                   # Composio Google OAuth config covering Gmail + Calendar scopes

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000   # backend CORS origin

# Copy frontend/.env.example → frontend/.env.local:
NEXT_PUBLIC_API_URL=http://localhost:8000
