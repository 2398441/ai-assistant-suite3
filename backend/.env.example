# AI Provider
ANTHROPIC_API_KEY=your-anthropic-api-key-here
MODEL_NAME=claude-opus-4-6

# Composio
COMPOSIO_API_KEY=your-composio-api-key-here
GMAIL_AUTH_CONFIG_ID=your-gmail-auth-config-id-here
CALENDAR_AUTH_CONFIG_ID=your-calendar-auth-config-id-here

# App
FRONTEND_URL=http://localhost:3000

# Email Summarizer mode: off | always | smart
#   off    — feature completely disabled
#   always — summarize on every login
#   smart  — only summarize emails not previously processed
EMAIL_SUMMARIZER_MODE=always

# Twilio WhatsApp (optional — leave empty to disable WA notifications)
# Dev/sandbox FROM number: whatsapp:+14155238886
# Production (dedicated number): whatsapp:+1XXXXXXXXXX
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SANDBOX_KEYWORD=your-sandbox-join-keyword
